generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model rooms {
  id        Int     @id @default(autoincrement())
  room_code String  @unique
  username  String
  topic     String
  turns     turns[]
}

model turns {
  id           Int     @id @default(autoincrement())
  room_id      Int
  username     String
  full_name    String
  first_name   String
  last_name    String
  prev_turn_id Int?
  turns        turns?  @relation("turnsToturns", fields: [prev_turn_id], references: [id], onUpdate: NoAction, map: "fk_prev_turn")
  other_turns  turns[] @relation("turnsToturns")
  rooms        rooms   @relation(fields: [room_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_turns_room")

  @@unique([room_id, full_name], map: "room_turn_unique")
}
