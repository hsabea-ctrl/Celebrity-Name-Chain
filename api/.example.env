# Copy this file to ".env" and fill in your own database connection string.
#
#   cp .env.example .env
#
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
# A typical local Postgres install looks like this:

DATABASE_URL="postgresql://postgres:postgres@localhost:5432/celebrity_name?schema=public"

# The port the API listens on (optional, defaults to 3000).
PORT=3000